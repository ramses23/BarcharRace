{
  "name": "global_electricity_sources",
  "chart": {
    "title": "Electricity by Source",
    "output_file": "output/global_electricity_sources.mp4",
    "frames_dir": "output/global_electricity_sources_frames",
    "layout_preset": "youtube_1080p",
    "theme": "clean_report",
    "value_format": "decimal",
    "typography_preset": "editorial",
    "fps": 24,
    "steps_per_transition": 24,
    "left_margin": 420,
    "source_x": 420,
    "title_max_width": 1300,
    "source_max_width": 1100,
    "rank_labels_enabled": true,
    "rank_label_prefix": "#",
    "rank_label_min_x": 96,
    "rank_label_label_gap": 18,
    "label_min_x": 40,
    "value_label_gap": 16,
    "value_label_min_x": null,
    "auto_fit_bar_count": true,
    "max_visible_bars": 8,
    "bar_shadow_enabled": true,
    "bar_shadow_alpha": 0.12,
    "bar_shadow_offset_x": 5,
    "bar_shadow_offset_y": 4,
    "bar_gradient_enabled": true,
    "bar_gradient_lighten": 0.22
  },
  "animation": {
    "easing": "ease_out_cubic",
    "enter_exit": true,
    "value_smoothing": true
  },
  "selection": {
    "top_n": 8,
    "aggregate_other": false,
    "other_label": "Other",
    "other_color": "#A0A0A0"
  },
  "data_source": {
    "source_type": "csv",
    "csv_path": "data/datasets/global_electricity_sources.csv",
    "source_label_override": "Source: User-provided dataset, values in TWh"
  },
  "dataset": {
    "year_column": "year",
    "name_column": "country",
    "value_column": "value"
  }
}
